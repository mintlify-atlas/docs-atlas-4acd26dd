  "keyFeatures": [
    "Google Calendar integration with OAuth 2.0",
    "Real-time event synchronization via Server-Sent Events",
    "Todo list management with categories and scheduling",
    "Recurring events support with rrule",
    "End-to-end encryption for sensitive data",
    "Desktop application support with Electrobun",
    "Offline-first architecture with IndexedDB",
    "Calendar visibility controls and filtering"
  ],
  "publicApiSurface": [
    "POST /auth/google/login - Initiate Google OAuth login",
    "GET /auth/google/callback - Handle OAuth callback",
    "POST /auth/refresh - Refresh access tokens",
    "POST /auth/logout - Logout and clear session",
    "GET /calendar/google/calendars - List Google calendars",
    "POST /calendar/google/sync - Sync calendar events",
    "GET /calendar/events - Query cached events (SSE)",
    "POST /calendar/webhook - Handle Google Calendar webhooks",
    "GET /todos/lists - Get todo lists",
    "POST /todos/lists - Create todo list",
    "GET /todos/items - Get todo items",
    "POST /todos/items - Create todo item",
    "PATCH /todos/items/{id} - Update todo item",
    "DELETE /todos/items/{id} - Delete todo item",
    "POST /todos/reorder - Reorder todos"
  ]
}
